# ─────────────────────────────────────────────────────────────
# Houston Dance Floor Wraps — environment variables
# Copy this file to ".env.local" and fill in what you use.
# The site works WITHOUT any of these (leads are logged to the
# server console). Add one of the options below to receive leads.
# ─────────────────────────────────────────────────────────────

# Option A — Email leads with Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# LEAD_TO_EMAIL=htxdancefloorwraps@gmail.com
# LEAD_FROM_EMAIL=leads@houstondancefloorwraps.com

# Option B — Send leads to Zapier / Make / your CRM via webhook
# LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy
